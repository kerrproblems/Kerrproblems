{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "KerrProblems problem entry",
  "type": "object",
  "required": [
    "id",
    "title",
    "cluster",
    "theorem_status",
    "statement",
    "math_required",
    "why_it_matters",
    "completion_criteria",
    "implications",
    "difficulty",
    "family",
    "asymptotics",
    "coupling",
    "equation_level",
    "regime",
    "relevance",
    "fv_suitability",
    "fv_reason",
    "progress_summary",
    "dependencies",
    "references"
  ],
  "properties": {
    "id": { "type": "string", "pattern": "^K-[0-9]{3}$" },
    "title": { "type": "string", "minLength": 1 },
    "cluster": {
      "enum": [
        "exterior-stability",
        "interior-scc",
        "extremal",
        "rigidity-uniqueness",
        "spectral-scattering"
      ]
    },
    "theorem_status": {
      "enum": ["open", "partial", "conditional", "solved", "needs_review"]
    },
    "status": {
      "description": "Deprecated; use theorem_status",
      "enum": ["open", "partial", "conditional", "solved", "needs_review"]
    },
    "problem_type": {
      "enum": [
        "classical_frontier",
        "literature_reformulation",
        "quantitative_sharpening",
        "formalization_target",
        "speculative_direction"
      ]
    },
    "maturity": {
      "enum": ["well_scoped", "mostly_scoped", "provisional"]
    },
    "evidence_level": {
      "enum": ["primary_refs_present", "secondary_refs_only", "refs_missing"]
    },
    "verification_state": {
      "enum": [
        "verified_recently",
        "imported_unverified",
        "editorial_revision_needed"
      ]
    },
    "research_state": {
      "description": "Literature positioning vs synthesized targets (orthogonal to theorem_status).",
      "enum": [
        "solved_in_literature",
        "open_in_literature",
        "high_value_unformalized_direction"
      ]
    },
    "publish": {
      "type": "boolean",
      "description": "false excludes entry from main index / clusters / RSS; use provisional directory + pipeline page."
    },
    "origin_type": {
      "type": "string",
      "description": "e.g. standard_problem | extracted_from_partial_results | synthesized_from_field-needs"
    },
    "solution_pointer": {
      "type": ["object", "null"],
      "properties": {
        "theorem_statement": { "type": "string" },
        "solved_by": { "type": "string" },
        "year": { "type": ["integer", "null"] },
        "citation_key": { "type": "string" }
      }
    },
    "summary": { "type": "string" },
    "short_title": { "type": "string" },
    "problem_statement": { "type": "string" },
    "scope": { "type": "object" },
    "known_results": { "type": "array" },
    "remaining_gap": { "type": "string" },
    "status_explanation": { "type": "string" },
    "related_problem_ids": {
      "type": "array",
      "items": { "type": "string", "pattern": "^K-[0-9]{3}$" }
    },
    "last_verified_at": { "type": ["string", "null"] },
    "last_verified_by": { "type": ["string", "null"] },
    "editorial_notes": { "type": ["string", "null"] },
    "public_notes": { "type": ["string", "null"] },
    "tags": { "type": "array", "items": { "type": "string" } },
    "aliases": { "type": "array", "items": { "type": "string" } },
    "priority": { "type": "string" },
    "difficulty": { "type": "integer", "minimum": 1, "maximum": 5 },
    "family": {
      "type": "string",
      "enum": [
        "exact-kerr",
        "near-kerr-vacuum",
        "kerr-newman",
        "kerr-de-sitter",
        "kerr-ads",
        "nhek",
        "related-rotating-black-hole"
      ]
    },
    "asymptotics": {
      "type": "string",
      "enum": [
        "asymptotically-flat",
        "de-sitter",
        "anti-de-sitter",
        "mixed"
      ]
    },
    "coupling": { "enum": ["vacuum", "matter-coupled"] },
    "equation_level": {
      "type": "array",
      "items": {
        "enum": [
          "null-geodesics",
          "scalar-wave",
          "maxwell",
          "linearized-gravity",
          "full-einstein",
          "einstein-maxwell",
          "stationary-reduction",
          "spectral-operator",
          "inverse-problem"
        ]
      },
      "minItems": 1
    },
    "regime": {
      "type": "array",
      "items": {
        "enum": [
          "stationary",
          "linear",
          "nonlinear",
          "exterior",
          "interior",
          "extremal",
          "near-extremal"
        ]
      },
      "minItems": 1
    },
    "relevance": { "enum": ["pure-math", "mixed", "physics-facing"] },
    "fv_suitability": { "enum": ["high", "medium", "low"] },
    "fv_reason": { "type": "string", "minLength": 1 },
    "progress_summary": { "type": "string", "minLength": 1 },
    "dependencies": { "type": "array", "items": { "type": "string", "pattern": "^K-[0-9]{3}$" } },
    "related": { "type": "array", "items": { "type": "string", "pattern": "^K-[0-9]{3}$" } },
    "related_families_note": { "type": ["string", "null"] },
    "caution_note": { "type": ["string", "null"] },
    "references": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "key": { "type": "string" },
          "authors": { "type": "string" },
          "title": { "type": "string" },
          "venue": { "type": "string" },
          "year": { "type": ["integer", "null"] },
          "url": { "type": "string" },
          "arxiv": { "type": "string" },
          "doi": { "type": "string" },
          "note": { "type": "string" },
          "placeholder": { "type": "string" },
          "kind": { "enum": ["primary", "survey", "secondary"] },
          "relevance": { "type": "string" }
        }
      }
    }
  }
}
