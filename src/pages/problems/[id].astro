---
import Base from '../../layouts/Base.astro';
import {
  getAllProblems,
  CLUSTER_LABELS,
  getUnlocksMap,
  getRelatedByTags,
  needsEditorialBanner,
} from '../../lib/problems.js';
import {
  FAMILY_LABELS,
  ASYMPTOTICS_LABELS,
  COUPLING_LABELS,
  EQUATION_LEVEL_LABELS,
  REGIME_LABELS,
  RELEVANCE_LABELS,
  FV_LABELS,
  THEOREM_STATUS_LABELS,
  PROBLEM_TYPE_LABELS,
  MATURITY_LABELS,
} from '../../lib/taxonomy.js';

export async function getStaticPaths() {
  const problems = getAllProblems();
  return problems.map(p => ({
    params: { id: p.id },
    props: { problem: p, all: problems },
  }));
}

const { problem: p, all } = Astro.props;
const unlocksMap = getUnlocksMap(all);
const unlockIds = unlocksMap[p.id] || [];
const unlocks = unlockIds.map(id => all.find(x => x.id === id)).filter(Boolean);
const related = (p.related || []).map(id => all.find(x => x.id === id)).filter(Boolean);
const depends = (p.dependencies || []).map(id => all.find(x => x.id === id)).filter(Boolean);
const relatedByTags = getRelatedByTags(p, all, 8).filter(
  x => !p.related?.includes(x.id) && x.id !== p.id,
);
const showEditorialBanner = needsEditorialBanner(p);

function pips(n) {
  return Array.from({ length: 5 }, (_, i) => `<span class="pip${i < n ? ' filled' : ''}"></span>`).join('');
}

function fvClass(s) {
  if (s === 'high') return 'fv-badge--high';
  if (s === 'medium') return 'fv-badge--medium';
  return 'fv-badge--low';
}

function relClass(r) {
  if (r === 'pure-math') return 'rel-pure-math';
  if (r === 'mixed') return 'rel-mixed';
  return 'rel-physics-facing';
}

function badgeTheorem(ts) {
  const safe = String(ts || 'open').replace(/[^a-z_]/g, '');
  return `badge-${safe}`;
}

const scope = p.scope || {};
const knownResults = Array.isArray(p.known_results) ? p.known_results : [];
---
<Base title={`${p.id} — ${p.title}`} description={p.summary || p.problem_statement}>
  <div class="crumbs">
    <a href="/problems">Problems</a>
    <span style="margin: 0 0.5rem">→</span>
    <a href={`/clusters/${p.cluster}`}>{CLUSTER_LABELS[p.cluster]}</a>
    <span style="margin: 0 0.5rem">→</span>
    {p.id}
  </div>

  <div class="problem-layout">
    <article class="problem-main">
      {showEditorialBanner && (
        <div class="editorial-banner" role="status">
          <strong>Editorial notice.</strong>{' '}
          This entry needs editorial verification and should not be cited as a literature-grounded status
          summary yet.
        </div>
      )}

      <div style="margin-bottom: 1.5rem">
        <div class="problem-id-line">{p.id}</div>
        <h1 style="font-size: 2rem; margin-bottom: 1rem; line-height: 1.2">{p.title}</h1>
        <div style="display: flex; gap: 0.5rem; flex-wrap: wrap; align-items: center; margin-bottom: 0.75rem">
          <span class={`badge ${badgeTheorem(p.theorem_status)}`} title="Theorem status">
            {THEOREM_STATUS_LABELS[p.theorem_status] || p.theorem_status}
          </span>
          <span class="badge-problem-type" title="Problem type">
            {PROBLEM_TYPE_LABELS[p.problem_type] || p.problem_type}
          </span>
          <span class="badge-maturity" title="Scoping maturity">
            {MATURITY_LABELS[p.maturity] || p.maturity}
          </span>
          <span class={`cluster-tag cluster-${p.cluster}`}>{CLUSTER_LABELS[p.cluster]}</span>
          <span class={`rel-badge ${relClass(p.relevance)}`} title="Relevance class">{RELEVANCE_LABELS[p.relevance]}</span>
          <span class={`fv-badge ${fvClass(p.fv_suitability)}`} title={p.fv_reason}>{FV_LABELS[p.fv_suitability]}</span>
          <span class="difficulty-pips" set:html={pips(p.difficulty)} title={`Difficulty: ${p.difficulty}/5`}></span>
        </div>
        <div style="display: flex; flex-wrap: wrap; margin-top: 0.5rem">
          <span class="tag-chip tag-chip--family" title="Family">{FAMILY_LABELS[p.family] || p.family}</span>
          <span class="tag-chip tag-chip--asymptotics">{ASYMPTOTICS_LABELS[p.asymptotics] || p.asymptotics}</span>
          <span class="tag-chip tag-chip--coupling">{COUPLING_LABELS[p.coupling] || p.coupling}</span>
          {(p.equation_level || []).map(e => (
            <span class="tag-chip tag-chip--equation">{EQUATION_LEVEL_LABELS[e] || e}</span>
          ))}
          {(p.regime || []).map(r => (
            <span class="tag-chip tag-chip--regime">{REGIME_LABELS[r] || r}</span>
          ))}
        </div>
      </div>

      <hr />

      <div class="problem-section">
        <h3>Summary</h3>
        <p>{p.summary}</p>
      </div>

      <div class="problem-section">
        <h3>Why this matters</h3>
        <p>{p.why_it_matters}</p>
      </div>

      <div class="problem-section">
        <h3>Exact scope</h3>
        <dl class="scope-block">
          <dt>Background / setting</dt>
          <dd>{scope.background}</dd>
          <dt>Equation type</dt>
          <dd>{scope.equation_type}</dd>
          <dt>Linearity</dt>
          <dd>{scope.linearity}</dd>
          <dt>Regularity</dt>
          <dd>{scope.regularity}</dd>
          <dt>Parameter regime</dt>
          <dd>{scope.parameter_regime}</dd>
          <dt>Asymptotics</dt>
          <dd>{scope.asymptotics}</dd>
          {scope.gauge_or_formulation && (
            <>
              <dt>Gauge / formulation</dt>
              <dd>{scope.gauge_or_formulation}</dd>
            </>
          )}
        </dl>
      </div>

      {p.status_explanation && String(p.status_explanation).trim() && (
        <div class="problem-section">
          <h3>Status explanation</h3>
          <p>{p.status_explanation}</p>
        </div>
      )}

      <div class="problem-section">
        <h3>Problem statement</h3>
        <p>{p.problem_statement}</p>
      </div>

      <div class="problem-section">
        <h3>What is already known</h3>
        {knownResults.length ? (
          <ul class="known-results-list">
            {knownResults.map(k => (
              <li>
                <div>{k.statement}</div>
                {k.regime && (
                  <div style="font-size: 0.88rem; color: var(--text-muted); margin-top: 0.35rem">
                    <em>Regime:</em> {k.regime}
                  </div>
                )}
                {k.significance && (
                  <div style="font-size: 0.88rem; margin-top: 0.35rem">{k.significance}</div>
                )}
              </li>
            ))}
          </ul>
        ) : (
          <p style="color: var(--text-muted)">No structured “known results” bullets recorded for this entry yet.</p>
        )}
        {p.progress_summary && (
          <p style="margin-top: 0.75rem; font-size: 0.92rem; color: var(--text-muted)">
            <em>Progress summary:</em> {p.progress_summary}
          </p>
        )}
      </div>

      <div class="problem-section">
        <h3>What remains open</h3>
        <p>{p.remaining_gap || p.completion_criteria}</p>
      </div>

      <div class="problem-section">
        <h3>Mathematical prerequisites</h3>
        <p>{p.math_required}</p>
      </div>

      {(p.related_families_note || p.caution_note) && (
        <div class="problem-section">
          <h3>Scope / taxonomy note</h3>
          {p.related_families_note && (
            <div class="callout callout--caution">
              <strong>Family nuance:</strong> {p.related_families_note}
            </div>
          )}
          {p.caution_note && (
            <div class="callout callout--caution">
              <strong>Caution:</strong> {p.caution_note}
            </div>
          )}
        </div>
      )}

      <div class="problem-section">
        <h3>Completion criteria</h3>
        <p>{p.completion_criteria}</p>
      </div>

      <div class="problem-section">
        <h3>Implications if solved</h3>
        <p>{p.implications}</p>
      </div>

      <div class="problem-section">
        <h3>Formal verification suitability</h3>
        <p>
          <span class={`fv-badge ${fvClass(p.fv_suitability)}`}>{FV_LABELS[p.fv_suitability]}</span>
        </p>
        <p style="margin-top: 0.5rem; max-width: 66ch">{p.fv_reason}</p>
        <p style="margin-top: 0.75rem; font-size: 0.9rem; color: var(--text-muted)">
          See <a href="/formal-verification">Formal verification</a> for how this database uses these labels.
        </p>
      </div>

      <div class="problem-section">
        <h3>References</h3>
        {!p.references?.length ? (
          <p style="color: var(--text-muted)">No references listed (often paired with <code>needs_review</code>).</p>
        ) : (
          <ul class="ref-list">
            {p.references.map(ref => (
              <li>
                <span class="ref-kind">{ref.kind}</span>
                {ref.url ? (
                  <a href={ref.url} target="_blank" rel="noopener">
                    {ref.title || ref.url}
                  </a>
                ) : (
                  <span>{ref.title || 'Reference'}</span>
                )}
                {ref.authors && <span style="color: var(--text-muted)"> — {ref.authors}</span>}
                {ref.year && <span style="color: var(--text-muted)"> ({ref.year})</span>}
                {ref.relevance && (
                  <div style="font-size: 0.88rem; color: var(--text-muted); margin-top: 0.25rem">
                    {ref.relevance}
                  </div>
                )}
              </li>
            ))}
          </ul>
        )}
      </div>

      {depends.length > 0 && (
        <div class="problem-section">
          <h3>Depends on</h3>
          <p class="page-meta" style="margin-bottom: 0.5rem">Conceptual dependencies (not necessarily logical lemmas in a proof assistant).</p>
          <ul class="dep-list">
            {depends.map(d => (
              <li><a href={`/problems/${d.id}`}>{d.id}</a> — {d.title}</li>
            ))}
          </ul>
        </div>
      )}

      {unlocks.length > 0 && (
        <div class="problem-section">
          <h3>Unlocks (other problems list this one as a dependency)</h3>
          <ul class="dep-list">
            {unlocks.map(d => (
              <li><a href={`/problems/${d.id}`}>{d.id}</a> — {d.title}</li>
            ))}
          </ul>
        </div>
      )}

      {related.length > 0 && (
        <div class="problem-section">
          <h3>Related problems</h3>
          <div class="problem-grid" style="margin-top: 0.6rem">
            {related.map(r => (
              <a href={`/problems/${r.id}`} class="problem-card">
                <div class="card-id">{r.id}</div>
                <div class="card-title">{r.title}</div>
                <div class="card-meta">
                  <span class={`badge ${badgeTheorem(r.theorem_status)}`}>{THEOREM_STATUS_LABELS[r.theorem_status] || r.theorem_status}</span>
                </div>
              </a>
            ))}
          </div>
        </div>
      )}

      {relatedByTags.length > 0 && (
        <div class="problem-section">
          <h3>Related by shared tags</h3>
          <p class="page-meta" style="margin-bottom: 0.5rem">Heuristic matches on family, cluster, equation level, asymptotics, and relevance.</p>
          <ul class="dep-list">
            {relatedByTags.map(r => (
              <li><a href={`/problems/${r.id}`}>{r.id}</a> — {r.title}</li>
            ))}
          </ul>
        </div>
      )}

      {(p.public_notes || p.editorial_notes || p.notes) && (
        <div class="problem-section">
          <h3>Editorial / maintainer notes</h3>
          {p.public_notes && <p style="white-space: pre-wrap">{p.public_notes}</p>}
          {p.editorial_notes && (
            <p style="color: var(--text-muted); font-style: italic; white-space: pre-wrap">{p.editorial_notes}</p>
          )}
          {p.notes && <p style="color: var(--text-muted); white-space: pre-wrap">{p.notes}</p>}
        </div>
      )}

      <hr />
      <div class="page-meta">
        Last updated: {p.last_updated || '—'}
        {p.last_verified_at && (
          <>
            {' '}
            · Last verified (editorial): {p.last_verified_at}
            {p.last_verified_by && ` (${p.last_verified_by})`}
          </>
        )}
        {' · '}
        <a href={`https://github.com/kerrproblems/Kerrproblems/blob/main/problems/${p.id}.yaml`} target="_blank" rel="noopener">Edit on GitHub →</a>
      </div>
    </article>

    <aside class="problem-meta-aside" aria-label="Problem metadata">
      <h2 style="font-size: 0.85rem; margin-bottom: 0.75rem; border-bottom: 1px solid var(--border); padding-bottom: 0.35rem">Metadata</h2>
      <dl class="metadata-dl">
        <dt>Cluster</dt>
        <dd><a href={`/clusters/${p.cluster}`}>{CLUSTER_LABELS[p.cluster]}</a></dd>
        <dt>Theorem status</dt>
        <dd><span class={`badge ${badgeTheorem(p.theorem_status)}`}>{THEOREM_STATUS_LABELS[p.theorem_status]}</span></dd>
        <dt>Problem type</dt>
        <dd>{PROBLEM_TYPE_LABELS[p.problem_type]}</dd>
        <dt>Maturity</dt>
        <dd>{MATURITY_LABELS[p.maturity]}</dd>
        <dt>Evidence</dt>
        <dd>{p.evidence_level}</dd>
        <dt>Verification</dt>
        <dd>{p.verification_state}</dd>
        <dt>Difficulty</dt>
        <dd>{p.difficulty} / 5</dd>
        <dt>Family</dt>
        <dd>{FAMILY_LABELS[p.family] || p.family}</dd>
        <dt>Asymptotics</dt>
        <dd>{ASYMPTOTICS_LABELS[p.asymptotics] || p.asymptotics}</dd>
        <dt>Coupling</dt>
        <dd>{COUPLING_LABELS[p.coupling] || p.coupling}</dd>
        <dt>Equation level</dt>
        <dd>{(p.equation_level || []).map(e => EQUATION_LEVEL_LABELS[e] || e).join(', ')}</dd>
        <dt>Regime</dt>
        <dd>{(p.regime || []).map(r => REGIME_LABELS[r] || r).join(', ')}</dd>
        <dt>Relevance</dt>
        <dd>{RELEVANCE_LABELS[p.relevance]}</dd>
        <dt>FV suitability</dt>
        <dd>{p.fv_suitability}</dd>
      </dl>
    </aside>
  </div>
</Base>
