---
import Base from '../../layouts/Base.astro';
import { getAllProblems, getStats, CLUSTER_LABELS } from '../../lib/problems.js';

export async function getStaticPaths() {
  return Object.keys(CLUSTER_LABELS).map(slug => ({
    params: { slug },
  }));
}

const { slug } = Astro.params;
const allProblems = getAllProblems();
const problems = allProblems.filter(p => p.cluster === slug);
const stats = getStats(problems);
const label = CLUSTER_LABELS[slug];
---
<Base title={label}>
  <div class="crumbs">
    <a href="/problems">Problems</a>
    <span style="margin: 0 0.5rem">→</span>
    {label}
  </div>

  <h1 style="margin-bottom: 1rem">{label}</h1>

  <p class="stats-line" style="margin-bottom: 2.5rem">
    {stats.total} problems · <span style="color: var(--open)">{stats.open} open</span> · <span style="color: var(--partial)">{stats.partial} partial</span> · <span style="color: var(--conditional)">{stats.conditional} conditional</span> · <span style="color: var(--solved)">{stats.solved} solved</span>
  </p>

  <div class="problem-grid">
    {problems.map(p => (
      <a href={`/problems/${p.id}`} class="problem-card">
        <div class="card-id">{p.id}</div>
        <div class="card-title">{p.title}</div>
        <div class="card-meta">
          <span class={`badge badge-${p.status}`}>{p.status}</span>
        </div>
      </a>
    ))}
  </div>
</Base>
