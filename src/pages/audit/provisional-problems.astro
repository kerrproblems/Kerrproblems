---
import Base from '../../layouts/Base.astro';
import { getProvisionalProblems, getProvisionalDirectoryProblems, CLUSTER_LABELS } from '../../lib/problems.js';
import {
  THEOREM_STATUS_LABELS,
  RESEARCH_STATE_LABELS,
  PROBLEM_TYPE_LABELS,
} from '../../lib/taxonomy.js';

const unpublished = getProvisionalProblems().sort((a, b) => a.id.localeCompare(b.id));
const inProvisionalDir = getProvisionalDirectoryProblems().sort((a, b) => a.id.localeCompare(b.id));
---
<Base title="Provisional pipeline">
  <div class="crumbs">
    <a href="/">Home</a>
    <span style="margin: 0 0.5rem">→</span>
    Provisional pipeline
  </div>

  <h1 style="margin-bottom: 0.5rem">Provisional pipeline</h1>
  <p style="max-width: 68ch; color: var(--text-muted); margin-bottom: 1.5rem">
    <strong>Unpublished</strong> (<code>publish: false</code>): omitted from the main index until curated —{' '}
    <strong>{unpublished.length}</strong> {unpublished.length === 1 ? 'entry' : 'entries'}.
    <strong> YAML in</strong> <code>data/problems_provisional/</code> (may still be listed on the index if{' '}
    <code>publish: true</code>): <strong>{inProvisionalDir.length}</strong> for editorial tracking until files move to{' '}
    <code>problems/</code>. See <a href="/methodology#publication">publication criteria</a>.
  </p>

  <h2 style="font-size: 1.1rem; margin: 1.25rem 0 0.5rem">Files in <code>data/problems_provisional/</code></h2>
  <p style="margin-bottom: 1rem">
    <strong>{inProvisionalDir.length}</strong> {inProvisionalDir.length === 1 ? 'entry' : 'entries'}.
  </p>

  <ul class="dep-list" style="max-width: 72ch">
    {inProvisionalDir.map(p => (
      <li style="margin-bottom: 0.65rem">
        <a href={`/problems/${p.id}`} style="font-weight: 600">{p.id}</a>
        {' — '}
        {p.title}
        <div style="font-size: 0.85rem; color: var(--text-muted); margin-top: 0.2rem">
          {CLUSTER_LABELS[p.cluster]} · {THEOREM_STATUS_LABELS[p.theorem_status]} ·{' '}
          {RESEARCH_STATE_LABELS[p.research_state]} · {PROBLEM_TYPE_LABELS[p.problem_type]}
        </div>
      </li>
    ))}
  </ul>
</Base>
