---
import Base from '../../layouts/Base.astro';
import { getProvisionalProblems, CLUSTER_LABELS } from '../../lib/problems.js';
import {
  THEOREM_STATUS_LABELS,
  RESEARCH_STATE_LABELS,
  PROBLEM_TYPE_LABELS,
} from '../../lib/taxonomy.js';

const provisional = getProvisionalProblems().sort((a, b) => a.id.localeCompare(b.id));
---
<Base title="Provisional pipeline">
  <div class="crumbs">
    <a href="/">Home</a>
    <span style="margin: 0 0.5rem">→</span>
    Provisional pipeline
  </div>

  <h1 style="margin-bottom: 0.5rem">Provisional pipeline</h1>
  <p style="max-width: 68ch; color: var(--text-muted); margin-bottom: 1.5rem">
    These entries have <code>publish: false</code> (currently all live under{' '}
    <code>data/problems_provisional/</code>). They are omitted from the main problem index and from cluster/RSS
    listings until references and editorial checks meet{' '}
    <a href="/methodology#publication">publication criteria</a>. Direct URLs remain valid for review.
  </p>

  <p style="margin-bottom: 1rem">
    <strong>{provisional.length}</strong> unpublished {provisional.length === 1 ? 'entry' : 'entries'}.
  </p>

  <ul class="dep-list" style="max-width: 72ch">
    {provisional.map(p => (
      <li style="margin-bottom: 0.65rem">
        <a href={`/problems/${p.id}`} style="font-weight: 600">{p.id}</a>
        {' — '}
        {p.title}
        <div style="font-size: 0.85rem; color: var(--text-muted); margin-top: 0.2rem">
          {CLUSTER_LABELS[p.cluster]} · {THEOREM_STATUS_LABELS[p.theorem_status]} ·{' '}
          {RESEARCH_STATE_LABELS[p.research_state]} · {PROBLEM_TYPE_LABELS[p.problem_type]}
        </div>
      </li>
    ))}
  </ul>
</Base>
